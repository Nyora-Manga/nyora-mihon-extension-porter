<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Marks this APK as a Mihon/Tachiyomi extension (ExtensionLoader requires
         this feature, else the package is not recognised → "package not found"). -->
    <uses-feature
        android:name="tachiyomi.extension"
        android:required="false" />

    <!-- Nyora-branded launcher icon: Mihon shows the extension's app icon for
         every source it provides, so all Nyora sources display the Nyora logo. -->
    <application
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="${nyoraName}">
        <!-- Entry point: a SourceFactory producing one source per kotatsu parser. -->
        <meta-data
            android:name="tachiyomi.extension.class"
            android:value="eu.kanade.tachiyomi.extension.all.nyoralocal.NyoraLocalSourceFactory" />

        <meta-data
            android:name="tachiyomix.name"
            android:value="${nyoraName}" />

        <!-- Required; must be 1.4 or 1.6 (ExtensionLoader.SUPPORTED_LIB_VERSIONS). -->
        <meta-data
            android:name="tachiyomix.extensionLib"
            android:value="1.6" />
    </application>
</manifest>
